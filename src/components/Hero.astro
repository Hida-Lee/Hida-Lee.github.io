---
const profileName = "히다";
const oneLineIntro = "웹에 남기고 싶은 생각, 작업, 기록을 정리합니다.";

const sections = [
	{
		title: "About",
		description: "나를 소개하는 글과 관심사를 정리할 공간입니다.",
	},
	{
		title: "Projects",
		description: "진행한 작업과 배운 내용을 모아둘 공간입니다.",
	},
	{
		title: "Posts",
		description: "짧은 글, 기록, 회고를 쌓아갈 공간입니다.",
	},
];
---

<section class="hero" aria-labelledby="home-title">
	<p class="eyebrow">Personal Website</p>
	<p class="name">{profileName}</p>
	<h1 id="home-title">안녕하세요. 히다의 홈페이지입니다.</h1>
	<p class="intro">{oneLineIntro}</p>
</section>

<section class="next-sections" aria-labelledby="next-title">
	<div class="section-heading">
		<p class="eyebrow">Next</p>
		<h2 id="next-title">앞으로 채워갈 공간</h2>
	</div>
	<div class="section-list">
		{
			sections.map((section) => (
				<article>
					<h3>{section.title}</h3>
					<p>{section.description}</p>
				</article>
			))
		}
	</div>
</section>

<style>
	.hero {
		display: grid;
		align-content: center;
		min-height: 58svh;
		padding: 7rem 0 5rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		color: #2563eb;
		font-size: 0.85rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.name {
		margin: 0 0 1.25rem;
		color: #4b5563;
		font-size: 1.15rem;
		font-weight: 700;
	}

	h1 {
		max-width: 760px;
		margin: 0;
		color: #111827;
		font-size: clamp(2.75rem, 6vw, 5.25rem);
		line-height: 1.08;
		letter-spacing: 0;
	}

	.intro {
		max-width: 620px;
		margin: 1.75rem 0 0;
		color: #374151;
		font-size: 1.2rem;
		line-height: 1.8;
	}

	.next-sections {
		padding: 2rem 0 7rem;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1.5rem;
		border-top: 1px solid #e5e7eb;
		padding-top: 2rem;
	}

	h2 {
		margin: 0;
		color: #111827;
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		line-height: 1.2;
		letter-spacing: 0;
	}

	.section-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	article {
		border: 1px solid #e5e7eb;
		border-radius: 8px;
		padding: 1.35rem;
		background: #ffffff;
	}

	h3 {
		margin: 0;
		color: #111827;
		font-size: 1.15rem;
		letter-spacing: 0;
	}

	article p {
		margin: 0.75rem 0 0;
		color: #4b5563;
		line-height: 1.65;
	}

	@media (max-width: 640px) {
		.hero {
			min-height: auto;
			padding: 4.5rem 0 4rem;
		}

		.section-heading {
			display: block;
		}

		.section-list {
			grid-template-columns: 1fr;
		}
	}
</style>
